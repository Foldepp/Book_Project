---
import Base from '../../layouts/Base.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import { chapters } from '../../data/chapters';

export async function getStaticPaths() {
  return chapters.map((chapter) => ({
    params: { slug: chapter.slug },
    props: { chapter },
  }));
}

const { chapter } = Astro.props;

const beduerfnisLabel: Record<string, string> = {
  runterkommen: 'Runterkommen',
  stabilisieren: 'Stabilisieren',
  nachspueren: 'Nachsp\u00fcren',
};

const dauerLabel: Record<string, string> = {
  '2min': '2 Min.',
  '5min': '5 Min.',
  '10min': '10 Min.',
};

const currentIndex = chapters.findIndex((c) => c.slug === chapter.slug);
const nextChapter = currentIndex < chapters.length - 1 ? chapters[currentIndex + 1] : null;
---
<Base title={`${chapter.titel} — Du bist genug`}>
  <a href="/kapitel" class="back-link">&#8592; Alle &#220;bungen</a>

  <div class="breadcrumb">Kapitel {chapter.nummer}</div>

  <h1>
    {chapter.titel.includes('—')
      ? <>
          {chapter.titel.split('—')[0].trim()} &mdash;<br />
          <em>{chapter.titel.split('—')[1].trim()}</em>
        </>
      : <em>{chapter.titel}</em>
    }
  </h1>

  <div class="tags">
    <span class="tag">{beduerfnisLabel[chapter.beduerfnis]}</span>
    <span class="tag">
      <span class="material-symbols-outlined">schedule</span>
      {dauerLabel[chapter.dauer]}
    </span>
  </div>

  <p class="context">{chapter.kapitelkontext}</p>

  <AudioPlayer
    audioSandra={chapter.audioSandra}
    audioCarsten={chapter.audioCarsten}
    textalternative={chapter.textalternative}
  />

  {nextChapter && (
    <div class="next-section">
      <a href={`/kapitel/${nextChapter.slug}`} class="next-card">
        <div class="next-label">N&#228;chste &#220;bung</div>
        <div class="next-title">
          {nextChapter.titel}
          <span class="material-symbols-outlined next-arrow">arrow_forward</span>
        </div>
      </a>
    </div>
  )}
</Base>

<style>
  .back-link {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
  }

  .back-link:hover {
    color: var(--color-text);
    opacity: 1;
  }

  .breadcrumb {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    font-family: var(--font-body);
  }

  h1 {
    font-size: 2.5rem;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  h1 em {
    color: var(--color-accent);
    font-style: italic;
  }

  @media (min-width: 640px) {
    h1 { font-size: 3.5rem; }
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    font-family: var(--font-body);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    background-color: var(--color-surface-high);
    border-radius: var(--radius-lg);
    padding: 5px 12px;
  }

  .tag .material-symbols-outlined {
    font-size: 15px;
  }

  .context {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    max-width: 38rem;
  }

  .next-section {
    margin-top: 3rem;
  }

  .next-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    background-color: var(--color-surface-high);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .next-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(81, 100, 71, 0.08);
    opacity: 1;
  }

  .next-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-family: var(--font-body);
  }

  .next-title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .next-arrow {
    font-size: 20px;
    color: var(--color-accent);
    transition: transform 0.2s;
  }

  .next-card:hover .next-arrow {
    transform: translateX(4px);
  }
</style>
