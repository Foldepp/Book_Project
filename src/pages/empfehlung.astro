---
import Base from '../layouts/Base.astro';
---
<Base title="Welche Übung passt zu dir? — Du bist genug">
  <a href="/" class="back-link">&#8592; Zur&#252;ck</a>
  <h1>Welche &#220;bung passt gerade zu dir?</h1>

  <form id="empfehlung-form">
    <textarea
      id="gefuehl-input"
      name="gefuehl"
      placeholder="Beschreib kurz, wie es dir gerade geht&#8230;"
      rows="4"
      required
    ></textarea>
    <p class="datenschutz">Deine Eingabe wird an einen KI-Dienst &#252;bertragen und nicht gespeichert.</p>
    <button type="submit" id="submit-btn">&#220;bung finden</button>
  </form>

  <div id="result-area" hidden>
    <p id="loading-text" hidden>Einen Moment&#8230;</p>
    <div id="empfehlung-output" hidden>
      <p id="empfehlung-text" class="empfehlung-satz"></p>
      <a id="uebung-card" href="#" class="card" hidden>
        <div class="card-meta">
          <span id="card-beduerfnis" class="tag"></span>
          <span id="card-dauer" class="tag"></span>
        </div>
        <h2 id="card-titel"></h2>
      </a>
      <div id="alternativen-bereich" hidden>
        <p class="alternativen-label">Weitere M&#246;glichkeiten</p>
        <div id="alternativen-liste"></div>
      </div>
    </div>
    <p id="error-text" class="error-text" hidden></p>
  </div>
</Base>

<script>
  const beduerfnisLabel: Record<string, string> = {
    runterkommen: 'Runterkommen',
    stabilisieren: 'Stabilisieren',
    nachspueren: 'Nachsp\u00fcren',
  };
  const dauerLabel: Record<string, string> = {
    '2min': '2 Min.',
    '5min': '5 Min.',
    '10min': '10 Min.',
  };

  const form = document.getElementById('empfehlung-form') as HTMLFormElement;
  const input = document.getElementById('gefuehl-input') as HTMLTextAreaElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const resultArea = document.getElementById('result-area') as HTMLDivElement;
  const loadingText = document.getElementById('loading-text') as HTMLParagraphElement;
  const empfehlungOutput = document.getElementById('empfehlung-output') as HTMLDivElement;
  const empfehlungText = document.getElementById('empfehlung-text') as HTMLParagraphElement;
  const uebungCard = document.getElementById('uebung-card') as HTMLAnchorElement;
  const cardTitel = document.getElementById('card-titel') as HTMLHeadingElement;
  const cardBeduerfnis = document.getElementById('card-beduerfnis') as HTMLSpanElement;
  const cardDauer = document.getElementById('card-dauer') as HTMLSpanElement;
  const alternativenBereich = document.getElementById('alternativen-bereich') as HTMLDivElement;
  const alternativenListe = document.getElementById('alternativen-liste') as HTMLDivElement;
  const errorText = document.getElementById('error-text') as HTMLParagraphElement;

  type Alt = { slug: string; titel: string; beduerfnis: string; dauer: string; grund: string };
  type Data = { empfehlung?: string; slug?: string; titel?: string; beduerfnis?: string; dauer?: string; alternativen?: Alt[]; error?: string };

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const gefuehl = input.value.trim();
    if (!gefuehl) return;

    resultArea.hidden = false;
    loadingText.hidden = false;
    empfehlungOutput.hidden = true;
    errorText.hidden = true;
    submitBtn.disabled = true;

    try {
      const res = await fetch('/api/empfehlung', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ gefuehl }),
      });

      let data: Data = {};
      try {
        data = await res.json();
      } catch {
        errorText.textContent = `Serverfehler (${res.status}). Bitte versuch es noch einmal.`;
        errorText.hidden = false;
        return;
      }

      if (!res.ok || data.error) {
        errorText.textContent = data.error ?? 'Ein Fehler ist aufgetreten. Bitte versuch es noch einmal.';
        errorText.hidden = false;
        return;
      }

      empfehlungText.textContent = data.empfehlung ?? '';

      if (data.slug && data.titel) {
        uebungCard.href = `/kapitel/${data.slug}`;
        cardTitel.textContent = data.titel;
        cardBeduerfnis.textContent = beduerfnisLabel[data.beduerfnis ?? ''] ?? '';
        cardDauer.textContent = dauerLabel[data.dauer ?? ''] ?? '';
        uebungCard.hidden = false;
      } else {
        uebungCard.hidden = true;
      }

      const alts = data.alternativen ?? [];
      if (alts.length > 0) {
        alternativenListe.innerHTML = '';
        alts.forEach((alt) => {
          const a = document.createElement('a');
          a.href = `/kapitel/${alt.slug}`;
          a.className = 'card alt-card';
          a.innerHTML = `
            <div class="card-meta">
              <span class="tag">${beduerfnisLabel[alt.beduerfnis] ?? ''}</span>
              <span class="tag">${dauerLabel[alt.dauer] ?? ''}</span>
            </div>
            <h2>${alt.titel}</h2>
            <p>${alt.grund}</p>`;
          alternativenListe.appendChild(a);
        });
        alternativenBereich.hidden = false;
      } else {
        alternativenBereich.hidden = true;
      }

      empfehlungOutput.hidden = false;
    } catch {
      errorText.textContent = 'Keine Verbindung m\u00f6glich. Bitte versuch es noch einmal.';
      errorText.hidden = false;
    } finally {
      loadingText.hidden = true;
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .back-link {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--color-text);
    opacity: 1;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-surface);
    color: var(--color-text);
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.6;
    resize: vertical;
    min-height: 120px;
  }

  textarea:focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
    border-color: var(--color-accent);
  }

  .datenschutz {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    margin-bottom: 0;
  }

  button {
    align-self: flex-start;
    background-color: var(--color-accent);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    padding: 0.75rem 1.5rem;
    font-family: inherit;
    font-size: 1rem;
    cursor: pointer;
  }

  button:hover:not(:disabled) { opacity: 0.85; }
  button:disabled { opacity: 0.5; cursor: not-allowed; }

  #result-area {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  #loading-text {
    color: var(--color-text-muted);
    font-style: italic;
  }

  #empfehlung-output {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .empfehlung-satz {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 0;
  }

  .card {
    display: block;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--color-accent);
    opacity: 1;
  }

  .card-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background-color: var(--color-accent-light);
    border-radius: 4px;
    padding: 2px 8px;
  }

  .card h2 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .alternativen-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  #alternativen-liste {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .error-text {
    color: #b94040;
    font-size: 0.9375rem;
  }
</style>
