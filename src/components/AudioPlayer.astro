---
interface Props {
  audioSandra: string;
  audioCarsten: string;
  textalternative: string;
}

const { audioSandra, audioCarsten, textalternative } = Astro.props;
const hasAudio = audioSandra.length > 0 || audioCarsten.length > 0;
const hasBoth = audioSandra.length > 0 && audioCarsten.length > 0;

const paragraphs = textalternative.split('\n\n').filter(Boolean);
---

<div class="audio-section">
  {hasAudio ? (
    <div class="player-wrap">
      {hasBoth && (
        <div class="voice-toggle" role="group" aria-label="Stimme wählen">
          <button class="voice-btn active" data-voice="sandra" type="button">Sandra</button>
          <button class="voice-btn" data-voice="carsten" type="button">Carsten</button>
        </div>
      )}
      <audio controls class="player" id="audio-player">
        <source src={audioSandra || audioCarsten} type="audio/mpeg" />
        Dein Browser unterstützt kein Audio. Bitte lies die Übungsanleitung unten.
      </audio>
    </div>
  ) : (
    <div class="audio-placeholder">
      Die Audiodatei wird in Kürze verfügbar sein.
    </div>
  )}

  <details class="text-alternative">
    <summary>Übungstext lesen</summary>
    <div class="text-content">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </details>
</div>

{hasBoth && (
  <script define:vars={{ audioSandra, audioCarsten }}>
    const player = document.getElementById('audio-player');
    const buttons = document.querySelectorAll('.voice-btn');

    const sources = { sandra: audioSandra, carsten: audioCarsten };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const voice = btn.dataset.voice;
        const currentTime = player.currentTime;
        const wasPlaying = !player.paused;

        player.src = sources[voice];
        player.load();
        player.currentTime = currentTime;
        if (wasPlaying) player.play();

        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });
  </script>
)}

<style>
  .audio-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .player-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .voice-toggle {
    display: flex;
    gap: 0.5rem;
  }

  .voice-btn {
    padding: 0.375rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-color: var(--color-surface);
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.875rem;
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background-color 0.15s;
  }

  .voice-btn.active {
    border-color: var(--color-accent);
    background-color: var(--color-accent-light);
    color: var(--color-text);
  }

  .voice-btn:hover:not(.active) {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .player {
    width: 100%;
    accent-color: var(--color-accent);
  }

  .audio-placeholder {
    background-color: var(--color-accent-light);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .text-alternative {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .text-alternative summary {
    padding: 0.75rem 1.25rem;
    cursor: pointer;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    background-color: var(--color-surface);
    user-select: none;
  }

  .text-alternative summary:hover {
    color: var(--color-text);
  }

  .text-content {
    padding: 1.25rem;
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    font-size: 0.9375rem;
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .text-content p {
    margin-bottom: 0;
  }
</style>
