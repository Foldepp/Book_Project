---
import type { Chapter } from '../data/chapters';

interface Props {
  chapter: Chapter;
}

const { chapter } = Astro.props;

const beduerfnisLabel: Record<string, string> = {
  runterkommen: 'Runterkommen',
  stabilisieren: 'Stabilisieren',
  nachspueren: 'Nachspüren',
};

const dauerLabel: Record<string, string> = {
  '2min': '2 Min.',
  '5min': '5 Min.',
  '10min': '10 Min.',
};
---
<a
  href={`/kapitel/${chapter.slug}`}
  class="card"
  data-beduerfnis={chapter.beduerfnis}
  data-dauer={chapter.dauer}
>
  <div class="card-meta">
    <span class="tag">{beduerfnisLabel[chapter.beduerfnis]}</span>
    <span class="tag">{dauerLabel[chapter.dauer]}</span>
  </div>
  <h2>{chapter.titel}</h2>
  <p>{chapter.kapitelkontext}</p>
</a>

<style>
  .card {
    display: block;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: var(--color-accent);
    opacity: 1;
  }

  .card-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    background-color: var(--color-accent-light);
    border-radius: 4px;
    padding: 2px 8px;
  }

  h2 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }
</style>
